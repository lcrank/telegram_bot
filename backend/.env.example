# ── Telegram Bot ────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── OpenAI ──────────────────────────────────────────────────────────────────────
# Required for STT (Whisper) and TTS (voice responses)
# If you want to also use OpenAI for the command interpreter, leave OPENROUTER_API_KEY empty.
OPENAI_API_KEY=sk-...

# ── OpenRouter (optional) ───────────────────────────────────────────────────────
# If set, the command interpreter (LLM agent) uses OpenRouter instead of OpenAI.
# This lets you use Claude, Llama, Gemini, etc. through a single API.
# OpenRouter key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini   # or: anthropic/claude-sonnet-4-20250514, meta-llama/llama-4-maverick, google/gemini-2.0-flash-001

# ── Security ────────────────────────────────────────────────────────────────────
# Must match AGENT_SECRET in the laptop agent's .env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SECRET=change-me-to-a-long-random-string

# ── Whitelist (optional) ────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs. Leave empty to allow all.
# Find your ID: message @userinfobot on Telegram
# TELEGRAM_ALLOWED_USER_IDS=[123456789]

# ── Telegram Webhook URL (optional) ─────────────────────────────────────────────
# Required for production. Your public HTTPS URL where the backend is hosted.
# WEBHOOK_URL=https://your-domain.com

# ── TTS Voice ───────────────────────────────────────────────────────────────────
# OpenAI TTS voice: alloy, echo, fable, nova, onyx, shimmer
# TTS_VOICE=nova

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Rate limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT=30/minute
