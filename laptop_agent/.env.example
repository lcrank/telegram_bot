# ── Backend WebSocket URL ──────────────────────────────────────────────────────
# Use wss:// in production (TLS), ws:// for local dev only
WS_URL=wss://your-server-domain.com

# ── Security ───────────────────────────────────────────────────────────────────
# Must match AGENT_SECRET in the backend's .env
AGENT_SECRET=change-me-to-a-long-random-string

# ── Reconnect delay (seconds) ─────────────────────────────────────────────────
RECONNECT_DELAY=5
